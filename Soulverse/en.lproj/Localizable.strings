// State-of-Change Q01-Q15
"quest_survey_soc_q01_text" = "I took steps to prevent myself from slipping back into old patterns.";
"quest_survey_soc_q02_text" = "I noticed areas in my life that might need attention, but I did not yet feel ready to make any changes.";
"quest_survey_soc_q03_text" = "I took clear and intentional actions to improve an area of my life.";
"quest_survey_soc_q04_text" = "I explored new ideas or perspectives that helped me reflect on how I might grow.";
"quest_survey_soc_q05_text" = "I felt a sense of stability and routine with the new habits I have developed.";
"quest_survey_soc_q06_text" = "I took proactive steps to learn what I needed to prepare for meaningful change.";
"quest_survey_soc_q07_text" = "I applied a new strategy or approach and took action to handle a challenge.";
"quest_survey_soc_q08_text" = "I consistently put effort into practicing a new behavior to replace an old one.";
"quest_survey_soc_q09_text" = "I felt okay staying where I was, even if I wasn't thinking about making any changes.";
"quest_survey_soc_q10_text" = "I began creating a realistic plan for a change I intend to make.";
"quest_survey_soc_q11_text" = "I recognized an area of my life that I might want to improve for my own benefit.";
"quest_survey_soc_q12_text" = "I took initial steps to build support for a change I am preparing to make.";
"quest_survey_soc_q13_text" = "I felt confident in my ability to maintain the positive changes I have already made.";
"quest_survey_soc_q14_text" = "I thoughtfully explored whether making a personal change might benefit my well-being.";
"quest_survey_soc_q15_text" = "I recognized that growth could be possible for me, even if I felt okay staying where I was.";

